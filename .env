# ── Adzuna API ─────────────────────────────────────────────────────────────
# Get free credentials at https://developer.adzuna.com
ADZUNA_APP_ID=****
ADZUNA_API_KEY=****

# ── Airflow ────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=**
_AIRFLOW_WWW_USER_PASSWORD=***

# ── Superset ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=changeme_superset_secret_32chars!!

# ── LocalStack (no real credentials needed) ────────────────────────────────
AWS_ACCESS_KEY_ID=**
AWS_SECRET_ACCESS_KEY=***
AWS_DEFAULT_REGION=us-east-1

# ── Local dev overrides (used when Airflow runs natively, not in Docker) ───
S3_ENDPOINT_URL=http://localhost:4566
ELASTICSEARCH_HOST=http://localhost:9200
DB_PATH=./data/lake.duckdb
